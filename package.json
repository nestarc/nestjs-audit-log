{
  "name": "@nestarc/audit-log",
  "version": "0.1.0",
  "description": "Audit logging module for NestJS with automatic Prisma change tracking and append-only PostgreSQL storage",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config test/e2e/jest-e2e.config.ts --runInBand",
    "prisma:test:generate": "prisma generate --schema=test/e2e/prisma/schema.prisma",
    "prisma:test:push": "dotenv -e .env.test -- prisma db push --schema=test/e2e/prisma/schema.prisma --skip-generate"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@prisma/client": "^5.0.0 || ^6.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestarc/tenancy": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "dotenv-cli": "^8.0.0",
    "express": "^5.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  }
}
