{
  "name": "@nestarc/audit-log",
  "version": "0.1.0",
  "description": "Audit logging module for NestJS with automatic Prisma change tracking and append-only PostgreSQL storage",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp src/sql/*.sql dist/sql/",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config test/e2e/jest-e2e.config.ts --runInBand",
    "prisma:test:generate": "prisma generate --schema=test/e2e/prisma/schema.prisma",
    "prisma:test:push": "npx dotenv -e .env.test -- npx prisma db push --schema=test/e2e/prisma/schema.prisma --skip-generate",
    "docker:up": "docker compose -f test/e2e/docker-compose.yml up -d",
    "docker:down": "docker compose -f test/e2e/docker-compose.yml down",
    "bench": "npx ts-node benchmarks/audit-overhead.ts",
    "test:e2e:setup": "npm run docker:up && sleep 2 && npm run prisma:test:push && npm run prisma:test:generate",
    "test:e2e:full": "npm run test:e2e:setup && npm run test:e2e",
    "test:e2e:teardown": "npm run docker:down"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestarc/tenancy": ">=0.1.0",
    "@prisma/client": "^5.0.0 || ^6.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestarc/tenancy": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "dotenv-cli": "^8.0.0",
    "express": "^5.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
